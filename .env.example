# ────────────────────────────────────────────
# Cal.com
# ────────────────────────────────────────────
# Get your API key: https://app.cal.com/settings/developer/api-keys
VITE_CAL_API_KEY=your_cal_api_key_here

# ────────────────────────────────────────────
# Firebase (create your own project at https://console.firebase.google.com)
# Project Settings → General → Your apps → Web app → Firebase SDK snippet → Config
# ────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ────────────────────────────────────────────
# Event config — change per show (CES, Computex, etc.)
# ────────────────────────────────────────────
VITE_APP_EVENT_NAME=CES
VITE_APP_YEAR=2026

# Optional: earliest booking year to show (defaults to VITE_APP_YEAR)
VITE_FILTER_YEAR_FROM=2026

# Display timezone, e.g. America/Los_Angeles (CES), Asia/Taipei (Computex)
VITE_TIMEZONE=America/Los_Angeles

# Locale for date formatting, e.g. en-US, zh-TW
VITE_LOCALE=en-US
