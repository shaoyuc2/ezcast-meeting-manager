rules_version = '2';

// Minimal starter rules — adjust to your security needs.
// Docs: https://firebase.google.com/docs/firestore/security/get-started
service cloud.firestore {
  match /databases/{database}/documents {

    // Option A (recommended): require Firebase Auth.
    // Enable Email/Password or Google sign-in in Firebase Console → Authentication,
    // then wire up sign-in in the client before using the app.
    match /members/{memberId} {
      allow read, write: if request.auth != null;
    }
    match /assignments/{assignmentId} {
      allow read, write: if request.auth != null;
    }

    // Option B (development only): allow all reads/writes.
    // DO NOT USE IN PRODUCTION — anyone with your projectId can read/write.
    // match /{document=**} {
    //   allow read, write: if true;
    // }
  }
}
